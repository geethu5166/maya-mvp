# ========================================
# MAYA SOC ENTERPRISE - ENVIRONMENT CONFIG
# ========================================
# SECURITY CRITICAL: Never commit .env to git
# Copy this file to .env and update with real values
# 
# Secret Generation Commands:
#   Symmetric key:    openssl rand -hex 32
#   Strong password:  openssl rand -base64 32
#   Token:           python -c "import secrets; secrets.token_urlsafe(32)"
# ========================================

# ====================
# ENVIRONMENT & DEBUG
# ====================
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ====================
# API CONFIGURATION
# ====================
API_HOST=0.0.0.0
API_PORT=8000

# ====================
# SECURITY & TOKENS
# ====================
# CRITICAL: Generate unique SECRET_KEY before deploying
# Command: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=MUST_SET_IN_ENV_VARIABLE

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================
# INITIAL ADMIN USER
# ====================
# CRITICAL: Use STRONG passwords (min 12 chars, upper, lower, numbers, symbols)
# Change immediately after first login
# Command: openssl rand -base64 32
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=MUST_CHANGE_BEFORE_PRODUCTION

# ====================
# DATABASE - POSTGRESQL (Phase 2)
# ====================
POSTGRES_USER=soc_user
POSTGRES_PASSWORD=MUST_SET_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=maya_soc
DATABASE_URL=postgresql://soc_user:MUST_SET_STRONG_PASSWORD@db:5432/maya_soc

# ====================
# MESSAGE BROKER - KAFKA (Phase 2)
# ====================
# For local development: kafka:9092
# For production: use managed Kafka or Kafka cluster
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=events
KAFKA_TOPIC_INCIDENTS=incidents
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_DETECTIONS=detections
KAFKA_CONSUMER_GROUP=maya-soc-consumer

# ====================
# CACHE - REDIS
# ====================
REDIS_URL=redis://redis:6379
REDIS_POOL_SIZE=50

# ====================
# MONITORING - PROMETHEUS (Phase 2)
# ====================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
METRICS_ENABLED=True

# ==================== 
# INCIDENT DETECTION (Phase 2)
# ====================
DETECTION_ENGINE_ENABLED=True
RULE_BASED_DETECTION=True
ANOMALY_DETECTION=True
THREAT_INTEL_DETECTION=True
BEHAVIORAL_DETECTION=False
CORRELATION_DETECTION=False

# ====================
# LOGGING
# ====================
LOG_DIR=./logs
LOG_FORMAT=json

# ====================
# SSH HONEYPOT
# ====================
SSH_HONEYPOT_ENABLED=true
SSH_HONEYPOT_PORT=2222
SSH_HONEYPOT_HOST=0.0.0.0

# ====================
# WEB HONEYPOT
# ====================
WEB_HONEYPOT_ENABLED=true
WEB_HONEYPOT_PORT=8888
WEB_HONEYPOT_HOST=0.0.0.0

# ====================
# DATABASE HONEYPOT
# ====================
DB_HONEYPOT_ENABLED=true
DB_HONEYPOT_PORT=3307
DB_HONEYPOT_HOST=0.0.0.0

# ====================
# EXTERNAL API KEYS
# ====================
# OpenAI (keep empty if not using AI features)
OPENAI_API_KEY=

# VirusTotal API Key for threat intelligence
VIRUSTOTAL_API_KEY=

# Shodan API Key for asset discovery
SHODAN_API_KEY=

# ====================
# ANOMALY DETECTION
# ====================
ANOMALY_THRESHOLD=0.7
RISK_SCORING_MODEL=ensemble

# ====================
# DECEPTION ENGINE
# ====================
POLYMORPHIC_DECEPTION_ENABLED=true
CANARY_DEPLOYMENT_ENABLED=true
COUNTER_INTEL_ENABLED=true

# ====================
# PRODUCTION SECURITY
# ====================
# TLS/SSL Certificate paths (for HTTPS)
SSL_CERT_PATH=/etc/ssl/certs/maya-soc.crt
SSL_KEY_PATH=/etc/ssl/private/maya-soc.key

# Data encryption key (for data at rest)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Encryption algorithm
ENCRYPTION_ALGORITHM=AES-256-GCM

# ====================
# HEADERS & SECURITY
# ====================
# Security headers
ENABLE_CORS=true
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ====================
# AUDIT & COMPLIANCE
# ====================
# Days to retain incidents
INCIDENT_RETENTION_DAYS=365

# Days to retain audit logs  
AUDIT_LOG_RETENTION_DAYS=2555

# ====================
# DEPLOYMENT
# ====================
# Docker container memory limit
MEMORY_LIMIT=2G

# Kubernetes namespace (if using K8s)
K8S_NAMESPACE=maya-soc

# ====================
# ALERTING
# ====================
# Slack webhook for critical alerts
SLACK_WEBHOOK_URL=

# Email for security alerts
ALERT_EMAIL_ADDRESS=security-team@company.com

# ====================
# PRODUCTION SECURITY CHECKLIST
# ====================
# BEFORE DEPLOYING TO PRODUCTION, VERIFY:
#
# 1. SECRETS MANAGEMENT:
#    ☐ All secrets are set via environment variables (NEVER hardcoded)
#    ☐ Using external secrets management (AWS Secrets Manager, Vault, etc.)
#    ☐ SECRET_KEY is cryptographically strong (32+ bytes)
#    ☐ Passwords are 32+ characters (upper, lower, numbers, special chars)
#    ☐ No secrets in git history (use git-secrets hook)
#    ☐ API keys rotated quarterly
#
# 2. DATABASE SECURITY:
#    ☐ POSTGRES_PASSWORD is strong and unique
#    ☐ Database uses strong authentication (SSL/TLS)
#    ☐ Database backups encrypted and stored separately
#    ☐ Database access restricted by IP/VPC
#    ☐ Automated daily backups configured
#    ☐ Test restore procedures monthly
#
# 3. KUBERNETES/DOCKER:
#    ☐ Images scanned for vulnerabilities
#    ☐ No root user execution
#    ☐ Resource limits set (MEMORY_LIMIT)
#    ☐ Network policies configured
#    ☐ Service account has minimal permissions
#
# 4. LOGGING & MONITORING:
#    ☐ LOG_FORMAT=json (structured logging)
#    ☐ Log retention configured (AUDIT_LOG_RETENTION_DAYS)
#    ☐ Logs stored on persistent, encrypted storage
#    ☐ Prometheus metrics enabled and monitored
#    ☐ Alerts configured for ERROR/CRITICAL logs
#    ☐ Centralized logging (ELK/CloudWatch/etc.)
#
# 5. NETWORK SECURITY:
#    ☐ HTTPS/TLS enabled with valid certificates
#    ☐ SSL certificates in secure storage (not git)
#    ☐ CORS_ORIGINS restricted to your domain only
#    ☐ Firewall rules allow only necessary ports
#    ☐ Rate limiting enabled (DETECTION_ENGINE_ENABLED)
#
# 6. ACCESS CONTROL:
#    ☐ All default credentials changed (INIT_ADMIN_PASSWORD)
#    ☐ Multi-factor authentication (MFA) enabled
#    ☐ JWT token expiry set appropriately (30+ minutes production)
#    ☐ API rate limiting configured
#    ☐ Service accounts use short-lived tokens
#
# 7. DATA PROTECTION:
#    ☐ Encryption at rest enabled (ENCRYPTION_KEY set)
#    ☐ Encryption in transit (HTTPS/TLS)
#    ☐ PII data masked in logs
#    ☐ Data retention policies enforced
#    ☐ GDPR compliance verified (if applicable)
#
# 8. INCIDENT RESPONSE:
#    ☐ Alerting configured (SLACK_WEBHOOK_URL)
#    ☐ Incident retention sufficient (INCIDENT_RETENTION_DAYS)
#    ☐ Automation enabled for response (deception engine, etc.)
#    ☐ Audit trail immutable and complete
#    ☐ Incident response runbooks documented
#
# FAILURE TO COMPLETE CHECKLIST WILL RESULT IN SECURITY VULNERABILITIES
