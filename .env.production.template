# ============================================================================
# MAYA SOC ENTERPRISE - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# CRITICAL: This is a TEMPLATE. COPY to .env.production and fill in values
# NEVER commit actual .env.production to version control
# ============================================================================

# Application Settings
ENV=production
DEBUG=false
APP_NAME=MAYA SOC Enterprise
APP_VERSION=1.0.0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# ============================================================================
# SECURITY SECRETS (REQUIRED - MUST BE SET)
# ============================================================================

# JWT Secret Key (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=MUST_GENERATE_STRONG_VALUE_32_CHARS_MIN

# Admin User Credentials (MUST CHANGE BEFORE FIRST RUN)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=MUST_SET_STRONG_PASSWORD_16_CHARS_MIN

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=soc_user
POSTGRES_PASSWORD=MUST_SET_STRONG_PASSWORD_16_CHARS_MIN
POSTGRES_DB=maya_soc

# Connection pooling
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# ============================================================================
# CACHE LAYER (Redis)
# ============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=MUST_SET_STRONG_PASSWORD_IF_PROTECTED
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ============================================================================
# MESSAGE QUEUE (Apache Kafka)
# ============================================================================

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Kafka Topics
KAFKA_TOPIC_EVENTS=security-events
KAFKA_TOPIC_INCIDENTS=security-incidents
KAFKA_TOPIC_ALERTS=security-alerts
KAFKA_TOPIC_RESPONSES=incident-responses

# Kafka Consumer Settings
KAFKA_CONSUMER_GROUP=maya-soc-v1
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=100

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/maya-soc.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# ============================================================================
# EXTERNAL APIS (Optional - for threat intelligence)
# ============================================================================

# OpenAI API (for AI-powered analysis)
OPENAI_API_KEY=sk-MUST_SET_IF_USING_OPENAI

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY=MUST_SET_IF_USING_VIRUSTOTAL
SHODAN_API_KEY=MUST_SET_IF_USING_SHODAN
CENSYS_API_KEY=MUST_SET_IF_USING_CENSYS

# ============================================================================
# AUTHENTICATION
# ============================================================================

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# OAuth2 (Optional)
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=

# ============================================================================
# CORS SETTINGS
# ============================================================================

CORS_ORIGINS=https://maya.vaultrap.com,https://vaultrap.com,https://www.vaultrap.com

# ============================================================================
# MONITORING & ALERTING
# ============================================================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Email Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=MUST_SET_APP_PASSWORD
ALERT_EMAIL_TO=soc-team@example.com

# ============================================================================
# SECURITY HARDENING
# ============================================================================

# Enable MFA
MFA_ENABLED=true

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_MINUTES=1

# ============================================================================
# DEPLOYMENT
# ============================================================================

DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_ZONE=zone-a

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================

# 1. All MUST_SET values MUST be changed before production
# 2. Use strong random passwords (min 16 chars) for database, admin user
# 3. Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 4. Never expose this file in logs or error messages
# 5. Use AWS Secrets Manager / HashiCorp Vault for production
# 6. Rotate secrets every 90 days
# 7. Monitor access to this file
